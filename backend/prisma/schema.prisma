generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(ADMIN)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Categoria {
  id        Int       @id @default(autoincrement())
  nome      String    @unique
  slug      String    @unique
  descricao String?
  imagem    String?
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  produtos  Produto[]

  @@map("categorias")
}

model Produto {
  id               Int           @id @default(autoincrement())
  nome             String
  slug             String        @unique
  descricao        String?
  preco            Decimal       @db.Decimal(10, 2)
  precoPromocional Decimal?      @db.Decimal(10, 2)
  estoque          Int           @default(0)
  sku              String?       @unique
  imagemPrincipal  String?
  imagens          String[]      @default([])
  destaque         Boolean       @default(false)
  ativo            Boolean       @default(true)
  categoriaId      Int
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  itensPedido      ItensPedido[]
  categoria        Categoria     @relation(fields: [categoriaId], references: [id])

  @@map("produtos")
}

model Cliente {
  id               Int           @id @default(autoincrement())
  nome             String
  email            String?       @unique
  telefone         String
  cpf              String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  senha            String?
  googleId         String?       @unique
  emailVerificado  Boolean       @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  verifyToken      String?
  agendamentos     Agendamento[]
  pedidos          Pedido[]

  @@map("clientes")
}

model Agendamento {
  id              Int               @id @default(autoincrement())
  clienteId       Int?
  nomeContato     String
  telefoneContato String
  email           String?
  whatsapp        String?
  endereco        String?
  cep             String?
  cidade          String?
  equipamento     String
  marca           String?
  modelo          String?
  problema        String
  observacoes     String?
  melhorHorario   String?
  dataAgendamento DateTime?
  status          StatusAgendamento @default(PENDENTE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  cliente         Cliente?          @relation(fields: [clienteId], references: [id])

  @@map("agendamentos")
}

model Pedido {
  id                Int           @id @default(autoincrement())
  clienteId         Int
  valorTotal        Decimal       @db.Decimal(10, 2)
  status            StatusPedido  @default(PENDENTE)
  observacoes       String?
  paymentStatus     String?
  paymentMethod     String?
  paymentId         String?
  preferenceId      String?
  externalReference String?
  paidAt            DateTime?

  nomeDestinatario  String?
  telefoneEntrega   String?
  cep               String?
  rua               String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  estado            String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  itens             ItensPedido[]
  cliente           Cliente       @relation(fields: [clienteId], references: [id])

  @@map("pedidos")
}

model ItensPedido {
  id            Int     @id @default(autoincrement())
  pedidoId      Int
  produtoId     Int
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto       Produto @relation(fields: [produtoId], references: [id])

  @@map("itens_pedido")
}

enum Role {
  ADMIN
  TECNICO
}

enum StatusAgendamento {
  PENDENTE
  CONFIRMADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum StatusPedido {
  PENDENTE
  PAGO
  ENVIADO
  ENTREGUE
  CANCELADO
}
